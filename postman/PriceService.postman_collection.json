{
  "info": {
    "name": "Price Service",
    "description": "Colección de pruebas para el Price Service (Inditex).\n\nEl endpoint acepta fechas en UTC (ISO-8601). Los tests de la especificación se enunciaron en hora de Madrid (CEST = UTC+2 en junio), por lo que se aplica la conversión correspondiente.\n\n**Conversión Madrid → UTC (junio, CEST UTC+2)**\n- 10:00 Madrid = 08:00 UTC\n- 15:00 Madrid = 13:00 UTC\n- 16:00 Madrid = 14:00 UTC\n- 18:30 Madrid = 16:30 UTC\n- 21:00 Madrid = 19:00 UTC\n- 00:00 Madrid = 22:00 UTC (día anterior)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "URL base del servicio"
    },
    {
      "key": "product_id",
      "value": "35455",
      "type": "string"
    },
    {
      "key": "brand_id",
      "value": "1",
      "type": "string",
      "description": "1 = ZARA"
    }
  ],
  "item": [
    {
      "name": "Escenarios de la especificación",
      "description": "Los 5 casos definidos en el enunciado de la prueba técnica (TestJava2024_1.txt).",
      "item": [
        {
          "name": "Test 1 — 10:00h del 14/Jun → PriceList 1 (35.50 EUR)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/prices?applicationDate=2020-06-14T08:00:00Z&productId={{product_id}}&brandId={{brand_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "prices"],
              "query": [
                { "key": "applicationDate", "value": "2020-06-14T08:00:00Z", "description": "10:00 Madrid (CEST) = 08:00 UTC" },
                { "key": "productId",       "value": "{{product_id}}" },
                { "key": "brandId",         "value": "{{brand_id}}" }
              ]
            },
            "description": "14 de junio a las 10:00h hora Madrid.\nEsperado: tarifa base (PriceList 1) → 35.50 EUR."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('productId = 35455',  () => pm.expect(json.productId).to.eql(35455));",
                  "pm.test('brandId = 1',        () => pm.expect(json.brandId).to.eql(1));",
                  "pm.test('priceList = 1',      () => pm.expect(json.priceList).to.eql(1));",
                  "pm.test('price = 35.50',      () => pm.expect(json.price).to.eql(35.50));",
                  "pm.test('currency = EUR',     () => pm.expect(json.currency).to.eql('EUR'));",
                  "pm.test('startDate present',  () => pm.expect(json.startDate).to.be.a('string'));",
                  "pm.test('endDate present',    () => pm.expect(json.endDate).to.be.a('string'));"
                ]
              }
            }
          ]
        },
