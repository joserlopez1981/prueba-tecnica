      "item": [
        {
          "name": "404 — Producto inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/prices?applicationDate=2000-01-01T00:00:00Z&productId=99999&brandId=99",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "prices"],
              "query": [
                { "key": "applicationDate", "value": "2000-01-01T00:00:00Z" },
                { "key": "productId",       "value": "99999" },
                { "key": "brandId",         "value": "99" }
              ]
            },
            "description": "Producto y marca que no existen en el sistema.\nEsperado: 404 Not Found con cuerpo ErrorResponse."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "const json = pm.response.json();",
                  "pm.test('status field = 404',       () => pm.expect(json.status).to.eql(404));",
                  "pm.test('error field = Not Found',  () => pm.expect(json.error).to.eql('Not Found'));",
                  "pm.test('message present',          () => pm.expect(json.message).to.be.a('string').and.not.empty);",
                  "pm.test('timestamp present',        () => pm.expect(json.timestamp).to.be.a('string'));"
                ]
              }
            }
          ]
